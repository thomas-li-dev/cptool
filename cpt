#!/usr/bin/env python3
"""Competitive Programming CLI tool.

Usage:
  cpt <name...>                Create problem folder(s), download samples from CC
  cpt <name...> --no-download  Create problem folder(s) without samples
"""

import argparse
import http.server
import json
import os
import re
import shutil
import signal
import subprocess
import sys
import threading

SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))
CONFIG_DIR = os.path.join(os.path.expanduser("~"), ".config", "cpt")
MAKEFILE_TEMPLATE = os.path.join(SCRIPT_DIR, "Makefile.template")
CC_PORT = 10042


def load_config():
    """Load config, initializing config dir with default template if needed."""
    os.makedirs(CONFIG_DIR, exist_ok=True)
    default_template = os.path.join(CONFIG_DIR, "template.cpp")
    if not os.path.isfile(default_template):
        src = os.path.join(SCRIPT_DIR, "template.cpp")
        if os.path.isfile(src):
            shutil.copy2(src, default_template)
            print(f"Initialized {CONFIG_DIR}")

    config = {"template": default_template}
    config_file = os.path.join(CONFIG_DIR, "config.json")
    if os.path.isfile(config_file):
        with open(config_file) as f:
            config.update(json.load(f))
    config["template"] = os.path.expanduser(config["template"])
    return config


def create_problem(name, config, samples=None):
    """Create a problem directory with template, Makefile, and optional samples."""
    if not re.match(r'^[A-Za-z0-9][A-Za-z0-9_-]*$', name):
        print(f"Error: '{name}' contains invalid characters. "
              f"Use only letters, digits, hyphens, and underscores.",
              file=sys.stderr)
        return False
    if os.path.exists(name):
        print(f"Error: '{name}' already exists", file=sys.stderr)
        return False

    os.makedirs(os.path.join(name, "samples"))

    cpp_path = os.path.join(name, f"{name}.cpp")
    template = config["template"]
    if os.path.isfile(template):
        shutil.copy2(template, cpp_path)
    else:
        print(f"Warning: template not found at {template}", file=sys.stderr)
        with open(cpp_path, "w"):
            pass

    with open(MAKEFILE_TEMPLATE) as f:
        makefile = f.read().replace("__PROG__", name)
    with open(os.path.join(name, "Makefile"), "w") as f:
        f.write(makefile)

    result = subprocess.run(["make", "-C", name, "compile_commands.json"],
                            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    if result.returncode != 0:
        print(f"Warning: failed to generate compile_commands.json for '{name}'",
              file=sys.stderr)

    if samples:
        for i, test in enumerate(samples, 1):
            with open(os.path.join(name, "samples", f"{i}.in"), "w") as f:
                f.write(test["input"])
            with open(os.path.join(name, "samples", f"{i}.out"), "w") as f:
                f.write(test["output"])

    return True


def listen_for_problems(count=1, port=CC_PORT):
    """Listen for Competitive Companion POST requests.

    Stops after receiving count problems. Ctrl+C to cancel early.
    """
    problems = []
    server_ref = [None]

    class Handler(http.server.BaseHTTPRequestHandler):
        def do_POST(self):
            body = self.rfile.read(int(self.headers["Content-Length"]))
            data = json.loads(body)
            problems.append(data)
            self.send_response(200)
            self.end_headers()
            print(f"  Received: {data.get('name', '?')} ({len(data.get('tests', []))} samples)")
            if len(problems) >= count:
                threading.Thread(target=server_ref[0].shutdown, daemon=True).start()

        def log_message(self, *_):
            pass

    class ReusableHTTPServer(http.server.HTTPServer):
        allow_reuse_address = True

    server = ReusableHTTPServer(("127.0.0.1", port), Handler)
    server_ref[0] = server
    old_handler = signal.signal(signal.SIGINT,
        lambda *_: threading.Thread(target=server.shutdown, daemon=True).start())

    print(f"Listening on port {port} for Competitive Companion...")
    if count > 1:
        print(f"Expecting {count} problems.")
    print("Press Ctrl+C to cancel.\n")

    server.serve_forever()
    server.server_close()
    signal.signal(signal.SIGINT, old_handler)
    return problems


def main():
    parser = argparse.ArgumentParser(description="Competitive Programming CLI tool")
    parser.add_argument("names", nargs="*", help="Problem/folder name(s)")
    parser.add_argument("--no-download", action="store_true",
                        help="Skip downloading samples from Competitive Companion")
    args = parser.parse_args()

    if not args.names:
        parser.print_help()
        sys.exit(1)

    config = load_config()

    if args.no_download:
        for name in args.names:
            if create_problem(name, config):
                print(f"Created '{name}/'")
    else:
        problems = listen_for_problems(count=len(args.names))
        if not problems:
            print("No data received.", file=sys.stderr)
            return
        if len(problems) < len(args.names):
            print(f"Warning: received {len(problems)} but expected {len(args.names)}.",
                  file=sys.stderr)
        created = []
        for name, data in zip(args.names, problems):
            samples = data.get("tests", [])
            if create_problem(name, config, samples=samples):
                print(f"  {name}: {data.get('name', '?')} ({len(samples)} samples)")
                created.append(name)
        if created:
            print(f"\nRun 'cd {created[0]} && make && make test' to build and test.")


if __name__ == "__main__":
    main()
