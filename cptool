#!/usr/bin/env python3
"""Competitive Programming CLI tool.

Commands:
  cptool problem <name...>                Create problem folder(s) (downloads from Competitive Companion)
  cptool problem <name...> --no-download  Create problem folder(s) without samples
"""

import argparse
import http.server
import json
import os
import shlex
import shutil
import signal
import subprocess
import sys
import threading

SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))
CONFIG_DIR = os.path.join(os.path.expanduser("~"), ".config", "cptool")
CONFIG_FILE = os.path.join(CONFIG_DIR, "config.json")
MAKEFILE_TEMPLATE = os.path.join(SCRIPT_DIR, "Makefile.template")
PCH_DIR = os.path.join(os.path.expanduser("~"), ".cache", "cptool", "pch")
CC_PORT = 10042  # Competitive Companion port (listed in default hosts)


def _ensure_config_dir():
    """Create config dir and copy default template if needed."""
    if not os.path.isdir(CONFIG_DIR):
        os.makedirs(CONFIG_DIR)
    default_template = os.path.join(CONFIG_DIR, "template.cpp")
    if not os.path.isfile(default_template):
        src = os.path.join(SCRIPT_DIR, "template.cpp")
        if os.path.isfile(src):
            shutil.copy2(src, default_template)
            print(f"Initialized config dir: {CONFIG_DIR}")
            print(f"  Copied default template to {default_template}")


def load_config():
    _ensure_config_dir()
    config = {"template": os.path.join(CONFIG_DIR, "template.cpp")}
    if os.path.isfile(CONFIG_FILE):
        with open(CONFIG_FILE, "r") as f:
            user = json.load(f)
        config.update(user)
    config["template"] = os.path.expanduser(config["template"])
    return config


def create_problem(name, config, base_dir=None, samples=None):
    """Create a problem directory with template, Makefile, and optional samples."""
    if base_dir is not None:
        prob_dir = os.path.join(base_dir, name)
    else:
        prob_dir = name

    if os.path.exists(prob_dir):
        print(f"Error: directory '{prob_dir}' already exists", file=sys.stderr)
        return False

    os.makedirs(prob_dir)
    os.makedirs(os.path.join(prob_dir, "samples"), exist_ok=True)

    # Copy template
    template_path = config["template"]
    if os.path.isfile(template_path):
        with open(template_path, "r") as f:
            template = f.read()
        with open(os.path.join(prob_dir, f"{name}.cpp"), "w") as f:
            f.write(template)
    else:
        print(f"Warning: template not found at {template_path}", file=sys.stderr)
        with open(os.path.join(prob_dir, f"{name}.cpp"), "w") as f:
            f.write("")

    # Write Makefile from template
    with open(MAKEFILE_TEMPLATE, "r") as f:
        makefile = f.read().replace("__PROG__", name)
    with open(os.path.join(prob_dir, "Makefile"), "w") as f:
        f.write(makefile)

    # Write samples
    if samples:
        for i, test in enumerate(samples, 1):
            with open(os.path.join(prob_dir, "samples", f"{i}.in"), "w") as f:
                f.write(test["input"])
            with open(os.path.join(prob_dir, "samples", f"{i}.out"), "w") as f:
                f.write(test["output"])

    return True


def listen_for_problems(count=None, multi=False, port=CC_PORT):
    """Listen for Competitive Companion POST requests.

    If count is given, stop after exactly that many problems.
    If multi is True, listen until Ctrl+C (or auto-stop on batch detection).
    Otherwise (single problem mode), stop after 1.
    Returns list of problem data dicts.
    """
    problems = []
    expected = [count]  # mutable so handler can update it
    server_ref = [None]

    class Handler(http.server.BaseHTTPRequestHandler):
        def do_POST(self):
            length = int(self.headers.get("Content-Length", 0))
            body = self.rfile.read(length)
            data = json.loads(body)
            problems.append(data)

            self.send_response(200)
            self.end_headers()

            name = data.get("name", "?")
            tests = len(data.get("tests", []))
            print(f"  Received: {name} ({tests} samples)")

            # Auto-detect batch size from contest batch info
            if expected[0] is None and multi:
                batch_size = data.get("batch", {}).get("size", 0)
                if batch_size > 1:
                    expected[0] = batch_size
                    print(f"  Contest detected: expecting {batch_size} problems total.")

            if expected[0] is not None and len(problems) >= expected[0]:
                threading.Thread(target=server_ref[0].shutdown, daemon=True).start()

        def log_message(self, format, *args):
            pass  # Suppress default logging

    class ReusableHTTPServer(http.server.HTTPServer):
        allow_reuse_address = True

    if count is None and not multi:
        expected[0] = 1  # single problem mode

    server = ReusableHTTPServer(("127.0.0.1", port), Handler)
    server_ref[0] = server

    # Handle Ctrl+C gracefully
    def sigint_handler(sig, frame):
        threading.Thread(target=server.shutdown, daemon=True).start()

    old_handler = signal.signal(signal.SIGINT, sigint_handler)

    print(f"Listening on port {port} for Competitive Companion...")
    print("Open the problem in your browser and click the Competitive Companion button.")
    if multi:
        print("Press Ctrl+C when done.\n")
    else:
        print("Press Ctrl+C to cancel.\n")

    server.serve_forever()
    server.server_close()
    signal.signal(signal.SIGINT, old_handler)

    return problems


def parse_makefile_flags():
    """Parse DEBUGFLAGS and FASTFLAGS from Makefile.template, expanding variable refs."""
    with open(MAKEFILE_TEMPLATE, "r") as f:
        content = f.read()

    variables = {}
    for line in content.splitlines():
        if "=" in line and not line.startswith("\t"):
            key, _, val = line.partition("=")
            key = key.strip()
            val = val.strip()
            if key in ("WARNFLAGS", "DEBUGFLAGS", "FASTFLAGS"):
                for vname, vval in variables.items():
                    val = val.replace(f"$({vname})", vval)
                variables[key] = val

    return variables


def cmd_pch(args):
    if args.clean:
        if os.path.isdir(PCH_DIR):
            shutil.rmtree(PCH_DIR)
            print("Removed precompiled headers.")
        else:
            print("No precompiled headers to remove.")
        return

    flags = parse_makefile_flags()
    gch_dir = os.path.join(PCH_DIR, "bits", "stdc++.h.gch")
    os.makedirs(gch_dir, exist_ok=True)

    # Create wrapper header that chains to the real system header
    header = os.path.join(PCH_DIR, "bits", "stdc++.h")
    with open(header, "w") as f:
        f.write(
            "#pragma GCC system_header\n"
            "#include_next <bits/stdc++.h>\n"
        )

    for name, flag_key in [("debug", "DEBUGFLAGS"), ("fast", "FASTFLAGS")]:
        out = os.path.join(gch_dir, f"{name}.gch")
        cmd = (
            ["g++", "-x", "c++-header"]
            + shlex.split(flags[flag_key])
            + [f"-I{PCH_DIR}", "-o", out, header]
        )
        print(f"Building {name} PCH...")
        result = subprocess.run(cmd)
        if result.returncode != 0:
            print(f"Error: failed to build {name} PCH.", file=sys.stderr)
            return

    print(f"\nPrecompiled headers built in {PCH_DIR}")
    print("They will be used automatically by make/make fast.")


def cmd_completion(args):
    """Print shell completion script."""
    shell = args.shell
    if shell is None:
        shell_path = os.environ.get("SHELL", "")
        if "zsh" in shell_path:
            shell = "zsh"
        else:
            shell = "bash"

    subcommands = "problem pch completion"

    if shell == "zsh":
        print("""\
#compdef cptool

_cptool() {
    local -a subcommands
    subcommands=(
        'problem:Create problem folder(s)'
        'pch:Build precompiled headers for bits/stdc++.h'
        'completion:Print shell completion script'
    )

    _arguments -C \\
        '1:command:->cmd' \\
        '*::arg:->args'

    case $state in
        cmd)
            _describe 'command' subcommands
            ;;
        args)
            case $words[1] in
                problem)
                    _arguments '*:name:' '--no-download[Skip downloading samples]'
                    ;;
                pch)
                    _arguments '--clean[Remove precompiled headers]'
                    ;;
                completion)
                    _arguments '1:shell:(bash zsh)'
                    ;;
            esac
            ;;
    esac
}

compdef _cptool cptool cpt
""")
    else:
        print(f"""\
_cptool() {{
    local cur prev
    cur="${{COMP_WORDS[COMP_CWORD]}}"
    prev="${{COMP_WORDS[COMP_CWORD-1]}}"

    if [ "$COMP_CWORD" -eq 1 ]; then
        COMPREPLY=($(compgen -W "{subcommands}" -- "$cur"))
        return
    fi

    case "${{COMP_WORDS[1]}}" in
        problem)
            COMPREPLY=($(compgen -W "--no-download" -- "$cur"))
            ;;
        pch)
            COMPREPLY=($(compgen -W "--clean" -- "$cur"))
            ;;
        completion)
            COMPREPLY=($(compgen -W "bash zsh" -- "$cur"))
            ;;
    esac
}}

complete -F _cptool cptool cpt
""")


def cmd_problem(args, config):
    names = args.names
    multi = len(names) > 1

    if args.no_download:
        for name in names:
            if create_problem(name, config):
                print(f"Created problem '{name}/'")
    else:
        problems = listen_for_problems(multi=multi)
        if not problems:
            print("No data received.", file=sys.stderr)
            return

        if len(problems) < len(names):
            print(f"Warning: received {len(problems)} problems but expected {len(names)}.",
                  file=sys.stderr)

        for name, data in zip(names, problems):
            samples = data.get("tests", [])
            if create_problem(name, config, samples=samples):
                prob_name = data.get("name", "?")
                n = len(samples)
                print(f"  {name}: {prob_name} ({n} samples)")

        print(f"\nCreated {len(names)} problem(s).")
        first = names[0]
        print(f"Run 'cd {first} && make && make test' to build and test.")


def main():
    parser = argparse.ArgumentParser(
        description="Competitive Programming CLI tool",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="command", required=True)

    # cptool problem <names...> [--no-download]
    p_prob = sub.add_parser(
        "problem",
        help="Create problem folder(s) (downloads from Competitive Companion by default)",
    )
    p_prob.add_argument("names", nargs="+", help="Problem/folder name(s)")
    p_prob.add_argument(
        "--no-download", action="store_true",
        help="Skip downloading samples from Competitive Companion",
    )

    # cptool pch [--clean]
    p_pch = sub.add_parser(
        "pch",
        help="Build precompiled headers for bits/stdc++.h",
    )
    p_pch.add_argument(
        "--clean", action="store_true", help="Remove precompiled headers",
    )

    # cptool completion [bash|zsh]
    p_comp = sub.add_parser(
        "completion",
        help="Print shell completion script",
    )
    p_comp.add_argument(
        "shell", nargs="?", default=None, choices=["bash", "zsh"],
        help="Shell type (default: auto-detect)",
    )

    args = parser.parse_args()

    if args.command == "completion":
        cmd_completion(args)
        return

    if args.command == "pch":
        cmd_pch(args)
        return

    config = load_config()

    if args.command == "problem":
        cmd_problem(args, config)


if __name__ == "__main__":
    main()
