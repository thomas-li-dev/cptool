#!/usr/bin/env python3
"""Competitive Programming CLI tool.

Commands:
  cptool new <name>                  Create a problem folder (no samples)
  cptool download <name>             Create a problem folder, listen for Competitive Companion
  cptool contest <name> <count>      Create a contest with count problems (no samples)
  cptool contest-download <name>     Create a contest, listen for Competitive Companion batch
"""

import argparse
import http.server
import json
import os
import signal
import sys
import threading

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
CONFIG_FILE = os.path.join(SCRIPT_DIR, "config.json")
CC_PORT = 10042  # Competitive Companion port (listed in default hosts)

DEFAULT_CONFIG = {
    "template": os.path.join(SCRIPT_DIR, "template.cpp"),
    "cxxflags": (
        "-O2 -std=c++17 -Wall -Wextra -pedantic -Wshadow -Wfloat-equal "
        "-Wconversion -Wlogical-op -Wshift-overflow=2 -fstack-protector-all "
        "-D_FORTIFY_SOURCE=2 -D_GLIBCXX_DEBUG -D_GLIBCXX_DEBUG_PEDANTIC"
    ),
}


def load_config():
    config = dict(DEFAULT_CONFIG)
    if os.path.isfile(CONFIG_FILE):
        with open(CONFIG_FILE, "r") as f:
            user = json.load(f)
        config.update(user)
    config["template"] = os.path.expanduser(config["template"])
    return config


def make_makefile(prog_name, cxxflags):
    """Generate Makefile content for a problem."""
    return f"""PROG = {prog_name}
CXXFLAGS = {cxxflags}

all: $(PROG)

$(PROG): $(PROG).cpp
\tg++ $(CXXFLAGS) -o $(PROG) $(PROG).cpp

test: $(PROG)
\t@passed=0; failed=0; total=0; \\
\tfor f in samples/*.in; do \\
\t\t[ -f "$$f" ] || continue; \\
\t\tbase=$$(basename "$$f" .in); \\
\t\ttotal=$$((total + 1)); \\
\t\texpected="samples/$$base.out"; \\
\t\tactual="samples/$$base.actual"; \\
\t\t./$(PROG) < "$$f" > "$$actual" 2>&1; \\
\t\tif [ ! -f "$$expected" ]; then \\
\t\t\techo "TEST $$base: NO EXPECTED OUTPUT"; \\
\t\t\techo "  Got:"; sed 's/^/    /' "$$actual"; \\
\t\telif diff -q "$$expected" "$$actual" > /dev/null 2>&1; then \\
\t\t\techo "TEST $$base: \\033[32mPASSED\\033[0m"; \\
\t\t\tpassed=$$((passed + 1)); \\
\t\telse \\
\t\t\techo "TEST $$base: \\033[31mFAILED\\033[0m"; \\
\t\t\techo "  Expected:"; sed 's/^/    /' "$$expected"; \\
\t\t\techo "  Got:"; sed 's/^/    /' "$$actual"; \\
\t\t\tfailed=$$((failed + 1)); \\
\t\tfi; \\
\tdone; \\
\techo ""; \\
\tif [ $$total -eq 0 ]; then \\
\t\techo "No test cases found in samples/"; \\
\telse \\
\t\techo "Results: $$passed/$$total passed"; \\
\t\tif [ $$failed -gt 0 ]; then exit 1; fi; \\
\tfi

# Generic rule for building other .cpp files in this directory
%: %.cpp
\tg++ $(CXXFLAGS) -o $@ $<

clean:
\trm -f $(PROG) samples/*.actual

.PHONY: all test clean
"""


def create_problem(name, config, base_dir=None, samples=None):
    """Create a problem directory with template, Makefile, and optional samples."""
    if base_dir:
        prob_dir = os.path.join(base_dir, name)
    else:
        prob_dir = name

    if os.path.exists(prob_dir):
        print(f"Error: directory '{prob_dir}' already exists", file=sys.stderr)
        return False

    os.makedirs(prob_dir)
    os.makedirs(os.path.join(prob_dir, "samples"), exist_ok=True)

    # Copy template
    template_path = config["template"]
    if os.path.isfile(template_path):
        with open(template_path, "r") as f:
            template = f.read()
        with open(os.path.join(prob_dir, f"{name}.cpp"), "w") as f:
            f.write(template)
    else:
        print(f"Warning: template not found at {template_path}", file=sys.stderr)
        with open(os.path.join(prob_dir, f"{name}.cpp"), "w") as f:
            f.write("")

    # Write Makefile
    with open(os.path.join(prob_dir, "Makefile"), "w") as f:
        f.write(make_makefile(name, config["cxxflags"]))

    # Write samples
    if samples:
        for i, test in enumerate(samples, 1):
            with open(os.path.join(prob_dir, "samples", f"{i}.in"), "w") as f:
                f.write(test["input"])
            with open(os.path.join(prob_dir, "samples", f"{i}.out"), "w") as f:
                f.write(test["output"])

    return True


def listen_for_problems(count=None):
    """Listen for Competitive Companion POST requests.

    If count is given, stop after that many problems.
    If count is None (auto mode), learn the batch size from the first request.
    Returns list of problem data dicts.
    """
    problems = []
    expected = [count]  # mutable so handler can update it
    server_ref = [None]

    class Handler(http.server.BaseHTTPRequestHandler):
        def do_POST(self):
            length = int(self.headers.get("Content-Length", 0))
            body = self.rfile.read(length)
            data = json.loads(body)
            problems.append(data)

            self.send_response(200)
            self.end_headers()

            name = data.get("name", "?")
            tests = len(data.get("tests", []))
            print(f"  Received: {name} ({tests} samples)")

            # Auto-detect batch size from first problem
            if expected[0] is None:
                batch_size = data.get("batch", {}).get("size", 1)
                expected[0] = batch_size
                if batch_size > 1:
                    print(f"  Contest detected: expecting {batch_size} problems total.")

            if expected[0] is not None and len(problems) >= expected[0]:
                threading.Thread(target=server_ref[0].shutdown, daemon=True).start()

        def log_message(self, format, *args):
            pass  # Suppress default logging

    class ReusableHTTPServer(http.server.HTTPServer):
        allow_reuse_address = True

    server = ReusableHTTPServer(("127.0.0.1", CC_PORT), Handler)
    server_ref[0] = server

    # Handle Ctrl+C gracefully
    def sigint_handler(sig, frame):
        print("\nCancelled.")
        threading.Thread(target=server.shutdown, daemon=True).start()

    old_handler = signal.signal(signal.SIGINT, sigint_handler)

    print(f"Listening on port {CC_PORT} for Competitive Companion...")
    print("Open the problem in your browser and click the Competitive Companion button.")
    if count is not None and count > 1:
        print(f"Expecting {count} problems.")
    print("Press Ctrl+C to cancel.\n")

    server.serve_forever()
    signal.signal(signal.SIGINT, old_handler)

    return problems


def cmd_new(args, config):
    name = args.name
    if create_problem(name, config):
        print(f"Created problem '{name}/'")
        print(f"  {name}/{name}.cpp")
        print(f"  {name}/Makefile")


def cmd_download(args, config):
    name = args.name
    problems = listen_for_problems(count=1)
    if not problems:
        print("No data received.", file=sys.stderr)
        return

    data = problems[0]
    samples = data.get("tests", [])

    if create_problem(name, config, samples=samples):
        print(f"\nCreated problem '{name}/'")
        print(f"  {name}/{name}.cpp")
        print(f"  {name}/Makefile")
        if samples:
            print(f"  {name}/samples/ ({len(samples)} test cases)")
            print(f"\nRun 'cd {name} && make && make test' to build and test.")


def cmd_contest(args, config):
    name = args.name
    count = args.count

    if os.path.exists(name):
        print(f"Error: directory '{name}' already exists", file=sys.stderr)
        return

    os.makedirs(name)

    labels = []
    for i in range(count):
        if i < 26:
            labels.append(chr(ord("A") + i))
        else:
            labels.append(f"A{i - 25}")

    for label in labels:
        create_problem(label, config, base_dir=name)

    print(f"Created contest '{name}/' with {count} problems:")
    for label in labels:
        print(f"  {name}/{label}/{label}.cpp")


def cmd_contest_download(args, config):
    name = args.name

    if os.path.exists(name):
        print(f"Error: directory '{name}' already exists", file=sys.stderr)
        return

    print("Waiting for contest data from Competitive Companion...")
    problems = listen_for_problems(count=None)  # auto-detect batch size
    if not problems:
        print("No data received.", file=sys.stderr)
        return

    os.makedirs(name)

    for i, data in enumerate(problems):
        if i < 26:
            label = chr(ord("A") + i)
        else:
            label = f"A{i - 25}"

        samples = data.get("tests", [])
        create_problem(label, config, base_dir=name, samples=samples)

        prob_name = data.get("name", "?")
        print(f"  {label}: {prob_name} ({len(samples)} samples)")

    print(f"\nCreated contest '{name}/' with {len(problems)} problems.")
    print(f"Run 'cd {name}/A && make && make test' to build and test problem A.")


def main():
    parser = argparse.ArgumentParser(
        description="Competitive Programming CLI tool",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="command", required=True)

    # cptool new <name>
    p_new = sub.add_parser("new", help="Create a problem folder (no samples)")
    p_new.add_argument("name", help="Problem/file name")

    # cptool download <name>
    p_dl = sub.add_parser(
        "download",
        help="Create a problem folder with samples from Competitive Companion",
    )
    p_dl.add_argument("name", help="Problem/file name")

    # cptool contest <name> <count>
    p_ct = sub.add_parser("contest", help="Create a contest folder (no samples)")
    p_ct.add_argument("name", help="Contest folder name")
    p_ct.add_argument("count", type=int, help="Number of problems")

    # cptool contest-download <name>
    p_cd = sub.add_parser(
        "contest-download",
        help="Create a contest folder with samples from Competitive Companion",
    )
    p_cd.add_argument("name", help="Contest folder name")

    args = parser.parse_args()
    config = load_config()

    if args.command == "new":
        cmd_new(args, config)
    elif args.command == "download":
        cmd_download(args, config)
    elif args.command == "contest":
        cmd_contest(args, config)
    elif args.command == "contest-download":
        cmd_contest_download(args, config)


if __name__ == "__main__":
    main()
