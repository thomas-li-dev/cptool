#!/usr/bin/env python3
"""Competitive Programming CLI tool.

Commands:
  cptool new <name>                  Create a problem folder (no samples)
  cptool download <name>             Create a problem folder, listen for Competitive Companion
  cptool contest <name> <count>      Create a contest with count problems (no samples)
  cptool contest-download <name>     Create a contest, listen for Competitive Companion batch
"""

import argparse
import http.server
import json
import os
import shlex
import shutil
import signal
import subprocess
import sys
import threading

SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))
CONFIG_DIR = os.path.join(os.path.expanduser("~"), ".config", "cptool")
CONFIG_FILE = os.path.join(CONFIG_DIR, "config.json")
MAKEFILE_TEMPLATE = os.path.join(SCRIPT_DIR, "Makefile.template")
PCH_DIR = os.path.join(os.path.expanduser("~"), ".cache", "cptool", "pch")
CC_PORT = 10042  # Competitive Companion port (listed in default hosts)


def _ensure_config_dir():
    """Create config dir and copy default template if needed."""
    if not os.path.isdir(CONFIG_DIR):
        os.makedirs(CONFIG_DIR)
    default_template = os.path.join(CONFIG_DIR, "template.cpp")
    if not os.path.isfile(default_template):
        src = os.path.join(SCRIPT_DIR, "template.cpp")
        if os.path.isfile(src):
            shutil.copy2(src, default_template)
            print(f"Initialized config dir: {CONFIG_DIR}")
            print(f"  Copied default template to {default_template}")


def load_config():
    _ensure_config_dir()
    config = {"template": os.path.join(CONFIG_DIR, "template.cpp")}
    if os.path.isfile(CONFIG_FILE):
        with open(CONFIG_FILE, "r") as f:
            user = json.load(f)
        config.update(user)
    config["template"] = os.path.expanduser(config["template"])
    return config


def problem_labels(count):
    """Generate problem labels: A-Z, then A1, A2, ..."""
    labels = []
    for i in range(count):
        if i < 26:
            labels.append(chr(ord("A") + i))
        else:
            labels.append(f"A{i - 25}")
    return labels


def create_problem(name, config, base_dir=None, samples=None):
    """Create a problem directory with template, Makefile, and optional samples."""
    if base_dir is not None:
        prob_dir = os.path.join(base_dir, name)
    else:
        prob_dir = name

    if os.path.exists(prob_dir):
        print(f"Error: directory '{prob_dir}' already exists", file=sys.stderr)
        return False

    os.makedirs(prob_dir)
    os.makedirs(os.path.join(prob_dir, "samples"), exist_ok=True)

    # Copy template
    template_path = config["template"]
    if os.path.isfile(template_path):
        with open(template_path, "r") as f:
            template = f.read()
        with open(os.path.join(prob_dir, f"{name}.cpp"), "w") as f:
            f.write(template)
    else:
        print(f"Warning: template not found at {template_path}", file=sys.stderr)
        with open(os.path.join(prob_dir, f"{name}.cpp"), "w") as f:
            f.write("")

    # Write Makefile from template
    with open(MAKEFILE_TEMPLATE, "r") as f:
        makefile = f.read().replace("__PROG__", name)
    with open(os.path.join(prob_dir, "Makefile"), "w") as f:
        f.write(makefile)

    # Write samples
    if samples:
        for i, test in enumerate(samples, 1):
            with open(os.path.join(prob_dir, "samples", f"{i}.in"), "w") as f:
                f.write(test["input"])
            with open(os.path.join(prob_dir, "samples", f"{i}.out"), "w") as f:
                f.write(test["output"])

    return True


def listen_for_problems(count=None, port=CC_PORT):
    """Listen for Competitive Companion POST requests.

    If count is given, stop after that many problems.
    If count is None (auto mode), learn the batch size from the first request.
    Returns list of problem data dicts.
    """
    problems = []
    expected = [count]  # mutable so handler can update it
    server_ref = [None]

    class Handler(http.server.BaseHTTPRequestHandler):
        def do_POST(self):
            length = int(self.headers.get("Content-Length", 0))
            body = self.rfile.read(length)
            data = json.loads(body)
            problems.append(data)

            self.send_response(200)
            self.end_headers()

            name = data.get("name", "?")
            tests = len(data.get("tests", []))
            print(f"  Received: {name} ({tests} samples)")

            # Auto-detect batch size from first problem
            if expected[0] is None:
                batch_size = data.get("batch", {}).get("size", 1)
                expected[0] = batch_size
                if batch_size > 1:
                    print(f"  Contest detected: expecting {batch_size} problems total.")

            if expected[0] is not None and len(problems) >= expected[0]:
                threading.Thread(target=server_ref[0].shutdown, daemon=True).start()

        def log_message(self, format, *args):
            pass  # Suppress default logging

    class ReusableHTTPServer(http.server.HTTPServer):
        allow_reuse_address = True

    server = ReusableHTTPServer(("127.0.0.1", port), Handler)
    server_ref[0] = server

    # Handle Ctrl+C gracefully
    def sigint_handler(sig, frame):
        print("\nCancelled.")
        threading.Thread(target=server.shutdown, daemon=True).start()

    old_handler = signal.signal(signal.SIGINT, sigint_handler)

    print(f"Listening on port {port} for Competitive Companion...")
    print("Open the problem in your browser and click the Competitive Companion button.")
    if count is not None and count > 1:
        print(f"Expecting {count} problems.")
    print("Press Ctrl+C to cancel.\n")

    server.serve_forever()
    server.server_close()
    signal.signal(signal.SIGINT, old_handler)

    return problems


def parse_makefile_flags():
    """Parse DEBUGFLAGS and FASTFLAGS from Makefile.template, expanding variable refs."""
    with open(MAKEFILE_TEMPLATE, "r") as f:
        content = f.read()

    variables = {}
    for line in content.splitlines():
        if "=" in line and not line.startswith("\t"):
            key, _, val = line.partition("=")
            key = key.strip()
            val = val.strip()
            if key in ("WARNFLAGS", "DEBUGFLAGS", "FASTFLAGS"):
                for vname, vval in variables.items():
                    val = val.replace(f"$({vname})", vval)
                variables[key] = val

    return variables


def cmd_pch(args):
    if args.clean:
        if os.path.isdir(PCH_DIR):
            shutil.rmtree(PCH_DIR)
            print("Removed precompiled headers.")
        else:
            print("No precompiled headers to remove.")
        return

    flags = parse_makefile_flags()
    gch_dir = os.path.join(PCH_DIR, "bits", "stdc++.h.gch")
    os.makedirs(gch_dir, exist_ok=True)

    # Create wrapper header that chains to the real system header
    header = os.path.join(PCH_DIR, "bits", "stdc++.h")
    with open(header, "w") as f:
        f.write(
            "#pragma GCC system_header\n"
            "#include_next <bits/stdc++.h>\n"
        )

    for name, flag_key in [("debug", "DEBUGFLAGS"), ("fast", "FASTFLAGS")]:
        out = os.path.join(gch_dir, f"{name}.gch")
        cmd = (
            ["g++", "-x", "c++-header"]
            + shlex.split(flags[flag_key])
            + [f"-I{PCH_DIR}", "-o", out, header]
        )
        print(f"Building {name} PCH...")
        result = subprocess.run(cmd)
        if result.returncode != 0:
            print(f"Error: failed to build {name} PCH.", file=sys.stderr)
            return

    print(f"\nPrecompiled headers built in {PCH_DIR}")
    print("They will be used automatically by make/make fast.")


def cmd_completion(args):
    """Print shell completion script."""
    shell = args.shell
    if shell is None:
        shell_path = os.environ.get("SHELL", "")
        if "zsh" in shell_path:
            shell = "zsh"
        else:
            shell = "bash"

    subcommands = "new download contest contest-download pch completion"

    if shell == "zsh":
        print("""\
#compdef cptool

_cptool() {
    local -a subcommands
    subcommands=(
        'new:Create a problem folder (no samples)'
        'download:Create a problem folder with samples from Competitive Companion'
        'contest:Create a contest folder (no samples)'
        'contest-download:Create a contest folder with samples from Competitive Companion'
        'pch:Build precompiled headers for bits/stdc++.h'
        'completion:Print shell completion script'
    )

    _arguments -C \\
        '1:command:->cmd' \\
        '*::arg:->args'

    case $state in
        cmd)
            _describe 'command' subcommands
            ;;
        args)
            case $words[1] in
                pch)
                    _arguments '--clean[Remove precompiled headers]'
                    ;;
                completion)
                    _arguments '1:shell:(bash zsh)'
                    ;;
                new|download|contest|contest-download)
                    _files -/
                    ;;
            esac
            ;;
    esac
}

compdef _cptool cptool
""")
    else:
        print(f"""\
_cptool() {{
    local cur prev
    cur="${{COMP_WORDS[COMP_CWORD]}}"
    prev="${{COMP_WORDS[COMP_CWORD-1]}}"

    if [ "$COMP_CWORD" -eq 1 ]; then
        COMPREPLY=($(compgen -W "{subcommands}" -- "$cur"))
        return
    fi

    case "${{COMP_WORDS[1]}}" in
        pch)
            COMPREPLY=($(compgen -W "--clean" -- "$cur"))
            ;;
        completion)
            COMPREPLY=($(compgen -W "bash zsh" -- "$cur"))
            ;;
        new|download|contest|contest-download)
            COMPREPLY=($(compgen -d -- "$cur"))
            ;;
    esac
}}

complete -F _cptool cptool
""")


def cmd_new(args, config):
    name = args.name
    if create_problem(name, config):
        print(f"Created problem '{name}/'")
        print(f"  {name}/{name}.cpp")
        print(f"  {name}/Makefile")


def cmd_download(args, config):
    name = args.name
    problems = listen_for_problems(count=1)
    if not problems:
        print("No data received.", file=sys.stderr)
        return

    data = problems[0]
    samples = data.get("tests", [])

    if create_problem(name, config, samples=samples):
        print(f"\nCreated problem '{name}/'")
        print(f"  {name}/{name}.cpp")
        print(f"  {name}/Makefile")
        if samples:
            print(f"  {name}/samples/ ({len(samples)} test cases)")
            print(f"\nRun 'cd {name} && make && make test' to build and test.")


def cmd_contest(args, config):
    name = args.name
    count = args.count

    if os.path.exists(name):
        print(f"Error: directory '{name}' already exists", file=sys.stderr)
        return

    os.makedirs(name)

    labels = problem_labels(count)
    for label in labels:
        create_problem(label, config, base_dir=name)

    print(f"Created contest '{name}/' with {count} problems:")
    for label in labels:
        print(f"  {name}/{label}/{label}.cpp")


def cmd_contest_download(args, config):
    name = args.name

    if os.path.exists(name):
        print(f"Error: directory '{name}' already exists", file=sys.stderr)
        return

    print("Waiting for contest data from Competitive Companion...")
    problems = listen_for_problems(count=None)  # auto-detect batch size
    if not problems:
        print("No data received.", file=sys.stderr)
        return

    os.makedirs(name)

    labels = problem_labels(len(problems))
    for label, data in zip(labels, problems):
        samples = data.get("tests", [])
        create_problem(label, config, base_dir=name, samples=samples)

        prob_name = data.get("name", "?")
        print(f"  {label}: {prob_name} ({len(samples)} samples)")

    print(f"\nCreated contest '{name}/' with {len(problems)} problems.")
    print(f"Run 'cd {name}/A && make && make test' to build and test problem A.")


def main():
    parser = argparse.ArgumentParser(
        description="Competitive Programming CLI tool",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="command", required=True)

    # cptool new <name>
    p_new = sub.add_parser("new", help="Create a problem folder (no samples)")
    p_new.add_argument("name", help="Problem/file name")

    # cptool download <name>
    p_dl = sub.add_parser(
        "download",
        help="Create a problem folder with samples from Competitive Companion",
    )
    p_dl.add_argument("name", help="Problem/file name")

    # cptool contest <name> <count>
    p_ct = sub.add_parser("contest", help="Create a contest folder (no samples)")
    p_ct.add_argument("name", help="Contest folder name")
    p_ct.add_argument("count", type=int, help="Number of problems")

    # cptool contest-download <name>
    p_cd = sub.add_parser(
        "contest-download",
        help="Create a contest folder with samples from Competitive Companion",
    )
    p_cd.add_argument("name", help="Contest folder name")

    # cptool pch [--clean]
    p_pch = sub.add_parser(
        "pch",
        help="Build precompiled headers for bits/stdc++.h",
    )
    p_pch.add_argument(
        "--clean", action="store_true", help="Remove precompiled headers",
    )

    # cptool completion [bash|zsh]
    p_comp = sub.add_parser(
        "completion",
        help="Print shell completion script",
    )
    p_comp.add_argument(
        "shell", nargs="?", default=None, choices=["bash", "zsh"],
        help="Shell type (default: auto-detect)",
    )

    args = parser.parse_args()

    if args.command == "completion":
        cmd_completion(args)
        return

    if args.command == "pch":
        cmd_pch(args)
        return

    config = load_config()

    if args.command == "new":
        cmd_new(args, config)
    elif args.command == "download":
        cmd_download(args, config)
    elif args.command == "contest":
        cmd_contest(args, config)
    elif args.command == "contest-download":
        cmd_contest_download(args, config)


if __name__ == "__main__":
    main()
